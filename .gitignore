# Compiled class file
*.class

# Log file
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files #
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*
replay_pid*

# Variables de entorno con secretos
api-keys.json
.env
.env.*
!.env.example

# Node.js dependencies (reinstalled via `npm ci`)
node_modules/

# Runtime-generated logs (recreated by request-log-middleware at startup)
logs/

# Generated test-run artifacts
tests/agentic/results/
coverage/

# ESLint machine-readable report (regenerated by `npm run lint:report`)
eslint-report.json

# Documentación interna/local — no se publica en el remoto
doc-agents/
doc-planning/
