{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "js-check",
            "type": "shell",
            "command": "npx tsc -p jsconfig.json --watch",
            "isBackground": true,
            "problemMatcher": "$tsc-watch",
            "presentation": {
                "reveal": "silent",
                "panel": "dedicated"
            },
            "runOptions": {
                "runOn": "folderOpen"
            }
        }
    ]
}
