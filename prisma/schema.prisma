generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Section {
  idSection Int @id
  idDataset Int
  block     Int

  dataset Dataset @relation(fields: [idDataset], references: [idDataset], onUpdate: Cascade, onDelete: Restrict)

  @@index([idDataset], map: "idx_section_dataset")
  @@map("Section")
}

model Dataset {
  idDataset            Int      @id @default(autoincrement())
  name                 String   @db.VarChar(128)
  entries              Int
  content              Bytes    @db.MediumBlob
  languages            String?  @db.Text
  completedPercent     Int      @default(0) @db.UnsignedTinyInt
  withoutReviewPercent Int      @default(0) @db.UnsignedTinyInt
  remainPercent        Int      @default(100) @db.UnsignedTinyInt
  colorClass           String   @default("dataset-purple") @db.VarChar(64)
  createdAt            DateTime @default(now()) @db.DateTime(0)
  updatedAt            DateTime @updatedAt @db.DateTime(0)

  entryRecords Entry[]
  sections     Section[]
  permits      Permits[]

  @@map("Dataset")
}

model User {
  idUser   Int    @id @default(autoincrement())
  email    String @unique @db.VarChar(255)
  password String @db.VarChar(255)
  role     String @default("annotator") @db.VarChar(32)

  annotations Annotation[]
  permits     Permits[]

  @@map("User")
}

model Permits {
  idDataset Int
  idUser    Int
  isOwned   Boolean

  dataset Dataset @relation(fields: [idDataset], references: [idDataset], onUpdate: Cascade, onDelete: Restrict)
  user    User    @relation(fields: [idUser], references: [idUser], onUpdate: Cascade, onDelete: Restrict)

  @@id([idDataset, idUser])
  @@index([idUser], map: "idx_permits_user")
  @@map("Permits")
}

model Entry {
  idEntry    Int     @id @default(autoincrement())
  idDataset  Int
  eid        Int     @db.UnsignedInt
  category   String  @db.VarChar(100)
  shape      String? @db.VarChar(50)
  shapeType  String? @map("shape_type") @db.VarChar(50)
  size       Int     @db.UnsignedTinyInt
  position   Int     @default(0) @db.UnsignedInt

  dataset       Dataset      @relation(fields: [idDataset], references: [idDataset], onDelete: Cascade, onUpdate: Cascade)
  triplesets    Tripleset[]
  lexes         Lex[]
  dbpediaLinks  Dbpedialink[]
  links         Link[]
  annotations   Annotation[]

  @@unique([idDataset, eid], map: "uq_entry_dataset_eid")
  @@unique([idDataset, position], map: "uq_entry_dataset_position")
  @@index([idDataset], map: "idx_entry_dataset")
  @@map("entry")
}

model Tripleset {
  idTripleset Int          @id @default(autoincrement()) @map("id") @db.UnsignedInt
  idEntry     Int          @db.UnsignedInt
  type        TriplesetType
  position    Int          @default(0) @db.UnsignedInt

  entry   Entry    @relation(fields: [idEntry], references: [idEntry], onDelete: Cascade, onUpdate: NoAction)
  triples Triple[]

  @@unique([idEntry, type, position], map: "uq_tripleset_entry_type_position")
  @@index([idEntry], map: "idx_tripleset_entry")
  @@map("tripleset")
}

model Triple {
  idTriple    Int    @id @default(autoincrement()) @map("id") @db.UnsignedInt
  idTripleset Int    @map("tripleset_id") @db.UnsignedInt
  position    Int    @default(0) @db.UnsignedInt
  subject     String @db.VarChar(500)
  predicate   String @db.VarChar(500)
  object      String @db.VarChar(500)

  tripleset Tripleset @relation(fields: [idTripleset], references: [idTripleset], onDelete: Cascade, onUpdate: NoAction)

  @@unique([idTripleset, position], map: "uq_triple_tripleset_position")
  @@index([idTripleset], map: "idx_triple_tripleset")
  @@map("triple")
}

model Lex {
  idLex    Int     @id @default(autoincrement()) @map("id") @db.UnsignedInt
  idEntry  Int     @db.UnsignedInt
  lid      String  @db.VarChar(20)
  lang     String  @db.Char(5)
  comment  String? @db.VarChar(500)
  text     String  @db.Text
  position Int     @default(0) @db.UnsignedInt

  entry Entry @relation(fields: [idEntry], references: [idEntry], onDelete: Cascade, onUpdate: NoAction)

  @@unique([idEntry, lid, lang], map: "uq_lex")
  @@index([idEntry], map: "idx_lex_entry")
  @@index([idEntry, position], map: "idx_lex_entry_position")
  @@map("lex")
}

model Dbpedialink {
  idDbpedialink Int    @id @default(autoincrement()) @map("id") @db.UnsignedInt
  idEntry       Int    @db.UnsignedInt
  direction     String @db.VarChar(20)
  subject       String @db.VarChar(500)
  predicate     String @db.VarChar(100)
  object        String @db.VarChar(500)
  position      Int    @default(0) @db.UnsignedInt

  entry Entry @relation(fields: [idEntry], references: [idEntry], onDelete: Cascade, onUpdate: NoAction)

  @@unique([idEntry, position], map: "uq_dbpedialink_entry_position")
  @@index([idEntry], map: "idx_dbpedialink_entry")
  @@map("dbpedialink")
}

model Link {
  idLink    Int    @id @default(autoincrement()) @map("id") @db.UnsignedInt
  idEntry   Int    @db.UnsignedInt
  direction String @db.VarChar(20)
  subject   String @db.VarChar(500)
  predicate String @db.VarChar(100)
  object    String @db.VarChar(500)
  position  Int    @default(0) @db.UnsignedInt

  entry Entry @relation(fields: [idEntry], references: [idEntry], onDelete: Cascade, onUpdate: NoAction)

  @@unique([idEntry, position], map: "uq_link_entry_position")
  @@index([idEntry], map: "idx_link_entry")
  @@map("link")
}

model Annotation {
  idAnnotation    Int      @id @default(autoincrement())
  idEntry         Int      @db.UnsignedInt
  idUser          Int
  sentenceIndex   Int      @db.UnsignedInt
  sentence        String   @db.Text
  rejectionReason String?  @db.Text
  createdAt       DateTime @default(now()) @db.DateTime(0)
  updatedAt       DateTime @updatedAt @db.DateTime(0)

  entry Entry @relation(fields: [idEntry], references: [idEntry], onDelete: Cascade, onUpdate: NoAction)
  user  User  @relation(fields: [idUser], references: [idUser], onDelete: Cascade, onUpdate: NoAction)

  @@unique([idEntry, idUser, sentenceIndex], map: "uq_annotation_entry_user_sentence")
  @@index([idUser], map: "idx_annotation_user")
  @@index([idEntry], map: "idx_annotation_entry")
  @@map("Annotation")
}

enum TriplesetType {
  original
  modified
}
