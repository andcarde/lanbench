# ============================================
# Dependencies (reinstalled inside the container)
# ============================================
node_modules
npm-debug.log
yarn-error.log
pnpm-debug.log

# ============================================
# Environment variables and secrets
# ============================================
api-keys.json
.env
.env.local
.env.*.local
*.pem
*.key

# ============================================
# Git and version control
# ============================================
.git
.gitignore
.gitattributes
.github

# ============================================
# IDEs and editors
# ============================================
.vscode
.idea
.claude
.sonarlint
*.swp
*.swo

# ============================================
# Documentation (not needed at runtime)
# ============================================
*.md
documentation
doc-agents
doc-planning
README.md
CLAUDE.md
FAILING-TESTS.md

# ============================================
# Test tooling/artifacts not needed in the image.
# NOTE: the test suites (tests/, *.test.js, *.spec.js) AND the fixtures
# they read (test-datasets/) are intentionally kept in the image so the
# documented `docker compose exec app npm run test:*` workflow works
# inside the container — there is no source bind-mount, so anything
# excluded here is simply absent at runtime.
# ============================================
front-mocks
coverage
jest.config.js

# ============================================
# Build artifacts and logs
# ============================================
dist
build
out
logs
*.log

# ============================================
# Stale database dumps (schema source of truth is prisma/schema.prisma)
# ============================================
database

# ============================================
# Development tooling configs
# ============================================
eslint.config.js
prettier.config.js
knip.json
.eslintrc*
.prettierrc*

# ============================================
# Docker itself (avoid recursion)
# ============================================
Dockerfile
docker-compose*.yaml
docker-compose*.yml
.dockerignore

# ============================================
# Operating system
# ============================================
.DS_Store
Thumbs.db
desktop.ini