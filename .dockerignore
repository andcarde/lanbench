# ============================================
# Dependencies (reinstalled inside the container)
# ============================================
node_modules
npm-debug.log
yarn-error.log
pnpm-debug.log

# ============================================
# Environment variables and secrets
# ============================================
api-keys.json
.env
.env.*
!.env.example
*.pem
*.key

# ============================================
# Git and version control
# ============================================
.git
.gitignore
.gitattributes
.github

# ============================================
# IDEs and editors
# ============================================
.vscode
.vs
.idea
.claude
.devcontainer
.sonarlint
*.swp
*.swo

# ============================================
# Documentation (not needed at runtime)
# ============================================
*.md
documentation
doc-agents
doc-planning
README.md
CLAUDE.md
FAILING-TESTS.md

# Local third-party datasets; never send them to the Docker build context
documentation/webnlg_datasets
documentation/**/webnlg_datasets
documentation/webnlg-datasets
documentation/**/webnlg-datasets

# ============================================
# Test tooling/artifacts not needed in the image.
# NOTE: the test suites (tests/, *.test.js, *.spec.js) AND the fixtures
# they read (test-datasets/) are intentionally kept in the image so the
# documented `docker compose exec app npm run test:*` workflow works
# inside the container — there is no source bind-mount, so anything
# excluded here is simply absent at runtime.
# ============================================
front-mocks
coverage
jest.config.js
tests/agentic/results

# ============================================
# Build artifacts and logs
# ============================================
dist
build
out
logs
*.log

# ============================================
# Java / JVM crash and build artifacts
# ============================================
*.class
*.ctxt
.mtj.tmp/
hs_err_pid*
replay_pid*

# ============================================
# Package archives
# ============================================
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# ============================================
# Stale database dumps and backups
# (schema source of truth is prisma/schema.prisma)
# ============================================
database

# ============================================
# Development tooling configs
# ============================================
eslint.config.js
prettier.config.js
knip.json
.eslintrc*
.prettierrc*
eslint-report.json

# ============================================
# TFM memory (LaTeX) and its build/release artifacts — never in the image
# ============================================
memory
memory-release
memory-versions
scripts/memory
.texbuild/
.textbuild/
.overleaf-output/
memory/_build

# ============================================
# User uploads (bind-mounted at runtime, not baked into the image)
# ============================================
uploads

# ============================================
# Docker itself (avoid recursion)
# ============================================
Dockerfile
docker-compose*.yaml
docker-compose*.yml
.dockerignore

# ============================================
# Operating system
# ============================================
.DS_Store
Thumbs.db
desktop.ini
