{
  // Sandbox container that Claude Code runs INSIDE. It is separate from the
  // app stack in docker-compose.yaml (app/db/adminer). This box only sees the
  // repo folder, so the rest of C:/tmp, your C: drive, and your host git
  // credentials are invisible to it.
  "name": "lanbench-claude-sandbox",

  // Node 22 to match the project. Ships with git, npm, etc.
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22",

  // Run as the unprivileged user baked into the image (not root).
  "remoteUser": "node",

  // IMPORTANT: no "docker-in-docker" / "docker-outside-of-docker" feature here.
  // Mounting the host Docker socket would hand the agent root on your host and
  // defeat the whole sandbox. Leaving features empty keeps it sealed.
  "features": {},

  // Only the repo is mounted (this is the default Dev Containers behaviour).
  // => Open the lanbench folder specifically, NOT C:/tmp, or you'd mount all of tmp.

  // A little extra kernel hardening.
  "runArgs": ["--security-opt", "no-new-privileges"],

  // Install Claude Code inside the sandbox once the container is built.
  "postCreateCommand": "npm install -g @anthropic-ai/claude-code",

  "customizations": {
    "vscode": {
      "extensions": ["anthropic.claude-code"]
    }
  }
}
