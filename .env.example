# ─────────────────────────────────────────────────────────────────────────────
# Lanbench environment template. Copy to `.env` and fill in the secrets.
# `config.js` loads `.env` without overwriting variables already set in the
# process environment, and normalises every value to a safe default.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (MariaDB / MySQL) ───────────────────────────────────────────────
DB_HOST=db
DB_PORT=3306
DB_NAME=lanbench
DB_USER=lanbench
DB_PASSWORD=
# Used by the MariaDB container for the root account (docker-compose).
DB_ROOT_PASSWORD=

# ── HTTP server ──────────────────────────────────────────────────────────────
PORT=3000

# ── Sessions ─────────────────────────────────────────────────────────────────
# Must be a stable string of at least 32 characters. If absent/short, an
# ephemeral secret is generated and existing sessions are invalidated on restart.
SESSION_SECRET=

# ── LLM provider (global default) ────────────────────────────────────────────
# 'local' (Ollama) or 'cloud' (Groq).
MODEL=cloud
GROQ_API_KEY=
# Optional overrides for the global Groq client.
# GROQ_API_BASE=https://api.groq.com/openai/v1
# GROQ_MODEL=llama-3.3-70b-versatile
# Optional local Ollama settings (MODEL=local).
# OLLAMA_HOST=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2:3b

# ── Integration test secrets (optional) ─────────────────────────────────────
# Live key consumed only by `tests/integration/gemini/gemini-api.test.js`.
# Leave empty to skip the live Gemini smoke test.
GEMINI_API_KEY=

# ── Per-dataset LLM credentials (US-31) ──────────────────────────────────────
# Secret used to derive the AES-256-GCM key that encrypts per-dataset API keys
# at rest. MUST be stable: rotating it makes previously stored credentials
# unreadable. If empty, SESSION_SECRET is used as a fallback; if neither is set,
# storing a credential fails explicitly.
CREDENTIALS_ENCRYPTION_KEY=
